# Copy this file to .env and fill in real values. Never commit .env itself
# (already in .gitignore). docs/02-external-apis.md §2 has full setup notes
# for each key, including the required Google Cloud budget alert.

# Google Routes API (routes.googleapis.com) — billable, needs a GCP project
# with the Routes API enabled and a budget alert configured before use
# outside local dev (docs/02-external-apis.md §2).
EXPO_PUBLIC_GOOGLE_ROUTES_API_KEY=

# Auckland Transport GTFS Realtime subscription key (dev-portal.at.govt.nz)
# — powers live bus/train delay data (docs/02-external-apis.md §2, Phase 7).
EXPO_PUBLIC_AT_SUBSCRIPTION_KEY=

# Open-Meteo needs no key.
